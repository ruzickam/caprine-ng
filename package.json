{
	"name": "caprine",
	"appName": "caprine",
	"productName": "Caprine",
	"version": "2.60.12",
	"description": "Elegant Facebook Messenger desktop app - Legacy OS Builds",
	"license": "MIT",
	"copyright": "Copyright © 2025 Michal Ruzicka",
	"repository": "https://github.com/ruzickam/caprine-ng",
	"author": {
		"name": "Michal Ruzicka",
		"email": "michalruz@centrum.cz"
	},
	"main": "dist-js",
	"engines": {
		"node": ">=25",
		"npm": ">=11"
	},
	"scripts": {
		"postinstall": "patch-package && electron-builder install-app-deps",
		"lint": "tsc && xo && stylelint \"css/**/*.css\"",
		"xo": "xo",
		"style": "stylelint \"css/**/*.css\"",
		"tsc": "tsc",
		"test": "npm run lint",
		"e": "electron . --ozone-platform=x11",
		"start": "tsc && electron . --ozone-platform=x11",
		"dev": "tsc && electron --enable-logging=file --user-data-dir=./test --ozone-platform=x11 .",
		"build": "npm run lint && electron-builder --dir",
		"clean": "rimraf ./dist && rimraf ./dist-js && rimraf ./test && rimraf ./node_modules",
		"distclean": "del-cli ./dist && del-cli ./dist-js",
		"burn": "rimraf package-lock.json",
		"distLinux": "npm run lint && electron-builder -l"
	},
	"dependencies": {
		"@electron/remote": "^2.1.3",
		"@sindresorhus/do-not-disturb": "^1.1.0",
		"electron-better-ipc": "^2.0.1",
		"electron-context-menu": "^3.6.1",
		"electron-debug": "^3.2.0",
		"electron-dl": "^3.5.2",
		"electron-localshortcut": "^3.2.1",
		"electron-store": "^8.2.0",
		"electron-updater": "^6.6.2",
		"electron-util": "^0.17.2",
		"element-ready": "^5.0.0",
		"is-online": "^12.0.2",
		"json-schema-typed": "^8.0.2",
		"lodash": "^4.17.21",
		"p-wait-for": "^3.2.0"
	},
	"devDependencies": {
		"@sindresorhus/tsconfig": "^0.7.0",
		"@types/electron-localshortcut": "^3.1.3",
		"@types/lodash": "^4.14.202",
		"del-cli": "^5.1.0",
		"electron": "^39.7.0",
		"electron-builder": "^26.8.1",
		"husky": "^9.1.7",
		"patch-package": "^8.0.1",
		"rimraf": "^3.0.2",
		"stylelint": "^14.16.1",
		"stylelint-config-xo": "^0.22.0",
		"typescript": "^5.4.5",
		"xo": "^1.2.3"
	},
	"xo": {
		"rules": {
			"@typescript-eslint/ban-ts-comment": "off",
			"@typescript-eslint/consistent-type-imports": "off",
			"@typescript-eslint/indent": "off",
			"@typescript-eslint/naming-convention": "off",
			"@typescript-eslint/no-floating-promises": "off",
			"@typescript-eslint/no-loop-func": "off",
			"@typescript-eslint/no-non-null-assertion": "off",
			"unicorn/prefer-dom-node-text-content": "warn",
			"unicorn/prefer-query-selector": "warn",
			"unicorn/prefer-string-slice": "warn",
			"unicorn/expiring-todo-comments": "off",
			"@typescript-eslint/no-require-imports": "off",
			"@typescript-eslint/no-unsafe-argument": "off",
			"@typescript-eslint/no-unsafe-assignment": "off",
			"@typescript-eslint/no-unsafe-call": "off",
			"@typescript-eslint/no-unsafe-enum-comparison": "off",
			"@typescript-eslint/no-var-requires": "off",
			"@typescript-eslint/padding-line-between-statements": "off",
			"@typescript-eslint/no-unsafe-return": "off",
			"@typescript-eslint/prefer-nullish-coalescing": "off",
			"@typescript-eslint/no-deprecated": "off",
			"@typescript-eslint/await-thenable": "off",
			"@typescript-eslint/switch-exhaustiveness-check": "off",
			"@typescript-eslint/no-restricted-types": "off",
			"import/extensions": "off",
			"import/no-anonymous-default-export": "off",
			"import/no-cycle": "off",
			"import-x/extensions": "off",
			"import-x/no-anonymous-default-export": "off",
			"n/prefer-global/process": "warn",
			"object-shorthand": "warn",
			"padding-line-between-statements": "warn",
			"semi": "warn",
			"n/file-extension-in-import": "off",
			"unicorn/prefer-at": "off",
			"unicorn/prefer-module": "off",
			"unicorn/prefer-top-level-await": "off",
			"unicorn/prefer-global-this": "off",
			"unicorn/no-anonymous-default-export": "off",
			"unicorn/consistent-existence-index-check": "off",
			"@stylistic/indent": "off",
			"@stylistic/multiline-ternary": "off",
			"@stylistic/function-paren-newline": "off",
			"@stylistic/indent-binary-ops": "off",
			"@stylistic/padding-line-between-statements": "off",
			"promise/prefer-await-to-then": "off"
		}
	},
	"stylelint": {
		"extends": "stylelint-config-xo",
		"rules": {
			"declaration-no-important": null,
			"no-descending-specificity": null,
			"no-duplicate-selectors": null,
			"rule-empty-line-before": null,
			"selector-class-pattern": null,
			"selector-id-pattern": null,
			"selector-max-class": null
		}
	},
	"husky": {
		"hooks": {
			"pre-push": "npm test"
		}
	}
}
